# Supabase 설정
# 이 파일을 .env.local로 복사하고 본인의 Supabase 프로젝트 값으로 변경하세요

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 포트원 / 아임포트 V1 (Vite는 프로젝트 루트 .env 권장)
# IMP.init — 가맹점 식별코드(보통 imp_ 로 시작)
VITE_PORTONE_USER_CODE=imp00000000
# IMP.request_pay — 채널 키(콘솔에서 발급)
VITE_PORTONE_CHANNEL_KEY=channel-key-xxxxxxxx

# Vercel /api/verify-payment 에서 imp_uid 검증 시 사용 (REST API용, 클라이언트에 넣지 마세요)
# https://admin.portone.io 또는 구 아임포트 콘솔의 API Key / API Secret
IAMPORT_API_KEY=
IAMPORT_API_SECRET=

# (레거시) 포트원 V2 결제 검증용 — V1만 쓰면 비워 둬도 됨
VITE_PORTONE_STORE_ID=
PORTONE_API_SECRET=
