# Supabase 설정
# 이 파일을 .env.local로 복사하고 본인의 Supabase 프로젝트 값으로 변경하세요

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 포트원 결제 (테스트: 카카오페이)
# admin.portone.io 가입 → 상점 생성 → 카카오페이 채널 추가(TC0ONETIME) 후 발급된 값 입력
VITE_PORTONE_STORE_ID=TC0ONETIME
VITE_PORTONE_CHANNEL_KEY=kakaopay.TC0ONETIME
